# Copy to `.env.local` (do not commit secrets). CRA only exposes vars prefixed with REACT_APP_.

# Optional: backend origin when the React app is not served from the same host as the API.
# Development: leave unset to use Create React App proxy to http://127.0.0.1:5000 (see package.json "proxy").
# Production: set to your HTTPS API root, e.g. https://api.yourdomain.com
# REACT_APP_API_URL=

# Optional: Socket.IO server origin. If unset in development, the client uses same-origin (proxy).
# Production: usually the same as the API unless you split services.
# REACT_APP_SOCKET_URL=
