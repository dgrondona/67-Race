# Copy to `.env` and adjust for production (do not commit real secrets).

FLASK_DEBUG=0
PORT=5000
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt
DATABASE_URL=sqlite:///app.db

# Comma-separated list of allowed browser origins, or * for any (dev only).
# Example production: https://your-app.netlify.app,https://www.yourdomain.com
CORS_ORIGINS=*

# Optional: override Socket.IO CORS; defaults to CORS_ORIGINS if unset.
# SOCKETIO_CORS_ORIGINS=
